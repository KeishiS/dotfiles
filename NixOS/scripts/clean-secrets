#!/usr/bin/env bash

set -euo pipefail

usage() {
    cat <<'EOF'
Usage: clean-decrypted-secrets.sh [--delete] [root]

Find plaintext files under any secrets/ directory and either print or delete them.

Retained files:
  - *.enc
  - *.enc.*

Examples:
  clean-decrypted-secrets.sh
  clean-decrypted-secrets.sh --delete
  clean-decrypted-secrets.sh --delete ./home-srv
EOF
}

delete_mode=0
root="."

while (($# > 0)); do
    case "$1" in
    --delete)
        delete_mode=1
        ;;
    -h | --help)
        usage
        exit 0
        ;;
    -*)
        echo "Unknown option: $1" >&2
        usage >&2
        exit 1
        ;;
    *)
        if [[ "$root" != "." ]]; then
            echo "Only one root path can be specified." >&2
            usage >&2
            exit 1
        fi
        root="$1"
        ;;
    esac
    shift
done

if [[ ! -d "$root" ]]; then
    echo "Root path does not exist: $root" >&2
    exit 1
fi

matches=()
while IFS= read -r -d '' path; do
    matches+=("$path")
done < <(
    find "$root" -type f -path '*/secrets/*' \
        ! -name '*.enc' \
        ! -name '*.enc.*' \
        -print0
)

if ((${#matches[@]} == 0)); then
    echo "No decrypted files found under secrets/."
    exit 0
fi

printf '%s\n' "${matches[@]}"

if ((delete_mode == 0)); then
    echo
    echo "Dry run only. Re-run with --delete to remove these files."
    exit 0
fi

rm -f -- "${matches[@]}"
echo
echo "Deleted ${#matches[@]} file(s)."
